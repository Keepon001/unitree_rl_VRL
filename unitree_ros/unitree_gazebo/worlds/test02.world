<?xml version="1.0" ?>
<!--
================================================================================
  变电站巡检场景 —— 高程图视觉感知专项测试
  Substation Inspection World for Elevation Map Perception Testing

  跑道总长：~19m (X轴) × 4m (Y轴)
  机器人出生点：x=0, y=0, z=0.5 (站在跑道原点)

  核心测试理念：
    如果不依赖高程图进行视觉感知（纯盲走），机器狗将在以下区域必死无疑：
    - 沟壑区：掉入 0.5m 深的电缆沟
    - 踏步石区：踩空落入泥泞积水区
    - 破损楼梯：踩空左半缺失台阶
    - 平台敞口：从检修口坠落

  障碍物布局（沿 X 轴正向，狗出生在原点）：
    0.0m -  6.0m | 起点平地 (6m长)      | 水泥加速缓冲区
    6.0m -  9.0m | 缺失盖板电缆沟        | 2条横向/斜向深沟（Gap）
    9.0m - 13.0m | 积水区离散设备基座     | 下沉0.3m + 6个踏步石墩（Stepping Stones）
   13.0m - 13.9m | 破损检修楼梯(3级)      | 第2级左半缺失
   13.9m - 15.9m | 金属网格观测平台       | 中央0.5×0.5m检修敞口（Hole）
   15.9m - 18.9m | 安全下行坡道           | 3m长缓坡回到地面
================================================================================
-->
<sdf version="1.5">
    <world name="substation_inspection_elevation">

        <!-- ============================================================
           物理引擎配置 (ODE)
           max_step_size=0.0002s → 5000Hz 仿真频率
           Quick 求解器 + 50次迭代，保证四足机器人足端接触稳定性
           ============================================================ -->
        <physics type="ode">
            <max_step_size>0.0002</max_step_size>
            <real_time_factor>1</real_time_factor>
            <real_time_update_rate>5000</real_time_update_rate>
            <gravity>0 0 -9.81</gravity>
            <ode>
                <solver>
                    <type>quick</type>
                    <iters>50</iters>
                    <sor>1.3</sor>
                </solver>
                <constraints>
                    <cfm>0.0</cfm>
                    <erp>0.2</erp>
                    <contact_max_correcting_vel>10.0</contact_max_correcting_vel>
                    <contact_surface_layer>0.001</contact_surface_layer>
                </constraints>
            </ode>
        </physics>

        <!-- 场景光照 -->
        <scene>
            <sky>
                <clouds><speed>12</speed></clouds>
            </sky>
        </scene>
        <include><uri>model://sun</uri></include>

        <!-- 默认无限大地平面 (z=0)，作为沟壑底部及最终地面 -->
        <include><uri>model://ground_plane</uri></include>

        <!-- ============================================================
           主场景模型
           ============================================================ -->
        <model name="substation_scene">
            <static>true</static>

            <!-- ========================================================
               0. 起点平地 (0.0m ~ 6.0m)
                  跑道表面高度 z=0.5，长 6m
                  狗出生在 x=0，站跑道中央
               ======================================================== -->
            <link name="start_zone">
                <pose>3.0 0 0.25 0 0 0</pose>
                <collision name="start_zone_collision">
                    <geometry>
                        <!-- 长6m 宽4m 厚0.5m，顶面 z=0.5 -->
                        <box><size>6.0 4.0 0.5</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="start_zone_visual">
                    <geometry>
                        <box><size>6.0 4.0 0.5</size></box>
                    </geometry>
                    <material>
                        <!-- 浅灰色水泥 -->
                        <ambient>0.45 0.45 0.45 1.0</ambient>
                        <diffuse>0.55 0.55 0.55 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- ========================================================
               1. 缺失盖板的电缆沟 (6.0m - 9.0m)
                  跑道表面 z=0.5，沟壑无碰撞体 → 盲走机器人直接坠落至 z=0

                  沟壑1 (横向): x=6.6-7.0, 宽0.4m, 横跨全跑道
                  沟壑2 (斜向): 左侧缺口 x=7.6-8.1, 右侧缺口 x=7.3-7.8
                               形成约 30° 斜向沟壑
               ======================================================== -->

            <!-- 电缆沟区跑道段1：x=6.0-6.6 (沟壑1前方) -->
            <link name="trench_seg_1">
                <pose>6.3 0 0.25 0 0 0</pose>
                <collision name="trench_seg_1_collision">
                    <geometry>
                        <box><size>0.6 4.0 0.5</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="trench_seg_1_visual">
                    <geometry>
                        <box><size>0.6 4.0 0.5</size></box>
                    </geometry>
                    <material>
                        <ambient>0.40 0.40 0.40 1.0</ambient>
                        <diffuse>0.50 0.50 0.50 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!--
                【沟壑1】x=6.6-7.0，宽0.4m，横向全宽
                此处无任何碰撞体 → 视觉感知盲区，机器人必坠 0.5m 至地面
            -->

            <!-- 电缆沟区跑道段2：x=7.0-7.6 (沟壑1后方/沟壑2前方) -->
            <link name="trench_seg_2">
                <pose>7.3 0 0.25 0 0 0</pose>
                <collision name="trench_seg_2_collision">
                    <geometry>
                        <box><size>0.6 4.0 0.5</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="trench_seg_2_visual">
                    <geometry>
                        <box><size>0.6 4.0 0.5</size></box>
                    </geometry>
                    <material>
                        <ambient>0.40 0.40 0.40 1.0</ambient>
                        <diffuse>0.50 0.50 0.50 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!--
                【沟壑2 - 斜向】宽约0.5m，左侧(x=7.6)比右侧(x=7.3)更靠前
                左半 (y<0): 缺口在 x=7.6-8.1
                右半 (y>0): 缺口在 x=7.3-7.8
                形成对角斜沟壑，增加跨越难度
            -->

            <!-- 电缆沟区跑道段3-左：x=8.1-9.0, y<0 (沟壑2左半后方) -->
            <link name="trench_seg_3L">
                <pose>8.55 -1.0 0.25 0 0 0</pose>
                <collision name="trench_seg_3L_collision">
                    <geometry>
                        <box><size>0.9 2.0 0.5</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="trench_seg_3L_visual">
                    <geometry>
                        <box><size>0.9 2.0 0.5</size></box>
                    </geometry>
                    <material>
                        <ambient>0.40 0.40 0.40 1.0</ambient>
                        <diffuse>0.50 0.50 0.50 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- 电缆沟区跑道段3-右：x=7.8-9.0, y>0 (沟壑2右半后方) -->
            <link name="trench_seg_3R">
                <pose>8.4 1.0 0.25 0 0 0</pose>
                <collision name="trench_seg_3R_collision">
                    <geometry>
                        <box><size>1.2 2.0 0.5</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="trench_seg_3R_visual">
                    <geometry>
                        <box><size>1.2 2.0 0.5</size></box>
                    </geometry>
                    <material>
                        <ambient>0.40 0.40 0.40 1.0</ambient>
                        <diffuse>0.50 0.50 0.50 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- ========================================================
               2. 积水区直线断桥 (9.0m - 13.0m)
                  地面整体下沉 0.3m → 泥泞积水区表面 z=0.2
                  7 个混凝土方柱沿 X 轴直线排列 (Y=0)
                  X 向边到边间距随机 (0.2m~0.5m)，高度随机差异 (±0.03m)
                  → 形成一条"断断续续的直线断桥"，无需寻路，直走即可
                  → 但仍需高程图精准检测每块石墩的高度和位置
               ======================================================== -->

            <!-- 泥泞积水区底板：x=9.0-13.0, 厚0.2m, 顶面 z=0.2 -->
            <link name="mud_basin">
                <pose>11.0 0 0.1 0 0 0</pose>
                <collision name="mud_basin_collision">
                    <geometry>
                        <box><size>4.0 4.0 0.2</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="mud_basin_visual">
                    <geometry>
                        <box><size>4.0 4.0 0.2</size></box>
                    </geometry>
                    <material>
                        <!-- 深褐色泥浆 -->
                        <ambient>0.12 0.08 0.02 1.0</ambient>
                        <diffuse>0.25 0.16 0.05 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!--
                踏步石墩 (Stepping Stones) —— 直线断桥
                Y=0 严格居中，X 方向随机间距，Z 方向微小高度差
                底盘 0.3×0.3m，高度 0.28~0.32m 不等 → 顶面 z≈0.48~0.52
            -->
            <!-- 石墩1: x=9.3, y=0, 高0.30m → 顶面 z=0.50 -->
            <link name="plinth_1">
                <pose>9.3 0 0.35 0 0 0</pose>
                <collision name="plinth_1_collision">
                    <geometry>
                        <box><size>0.3 0.3 0.30</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="plinth_1_visual">
                    <geometry>
                        <box><size>0.3 0.3 0.30</size></box>
                    </geometry>
                    <material>
                        <!-- 混凝土灰 -->
                        <ambient>0.45 0.45 0.45 1.0</ambient>
                        <diffuse>0.60 0.60 0.60 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- 石墩2: x=9.85 (间距0.25m), 高0.32m → 顶面 z=0.52 -->
            <link name="plinth_2">
                <pose>9.85 0 0.36 0 0 0</pose>
                <collision name="plinth_2_collision">
                    <geometry>
                        <box><size>0.3 0.3 0.32</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="plinth_2_visual">
                    <geometry>
                        <box><size>0.3 0.3 0.32</size></box>
                    </geometry>
                    <material>
                        <ambient>0.45 0.45 0.45 1.0</ambient>
                        <diffuse>0.60 0.60 0.60 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- 石墩3: x=10.55 (间距0.4m), 高0.28m → 顶面 z=0.48 -->
            <link name="plinth_3">
                <pose>10.55 0 0.34 0 0 0</pose>
                <collision name="plinth_3_collision">
                    <geometry>
                        <box><size>0.3 0.3 0.28</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="plinth_3_visual">
                    <geometry>
                        <box><size>0.3 0.3 0.28</size></box>
                    </geometry>
                    <material>
                        <ambient>0.45 0.45 0.45 1.0</ambient>
                        <diffuse>0.60 0.60 0.60 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- 石墩4: x=11.1 (间距0.25m), 高0.30m → 顶面 z=0.50 -->
            <link name="plinth_4">
                <pose>11.1 0 0.35 0 0 0</pose>
                <collision name="plinth_4_collision">
                    <geometry>
                        <box><size>0.3 0.3 0.30</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="plinth_4_visual">
                    <geometry>
                        <box><size>0.3 0.3 0.30</size></box>
                    </geometry>
                    <material>
                        <ambient>0.45 0.45 0.45 1.0</ambient>
                        <diffuse>0.60 0.60 0.60 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- 石墩5: x=11.8 (间距0.4m), 高0.31m → 顶面 z=0.51 -->
            <link name="plinth_5">
                <pose>11.8 0 0.355 0 0 0</pose>
                <collision name="plinth_5_collision">
                    <geometry>
                        <box><size>0.3 0.3 0.31</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="plinth_5_visual">
                    <geometry>
                        <box><size>0.3 0.3 0.31</size></box>
                    </geometry>
                    <material>
                        <ambient>0.45 0.45 0.45 1.0</ambient>
                        <diffuse>0.60 0.60 0.60 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- 石墩6: x=12.35 (间距0.25m), 高0.29m → 顶面 z=0.49 -->
            <link name="plinth_6">
                <pose>12.35 0 0.345 0 0 0</pose>
                <collision name="plinth_6_collision">
                    <geometry>
                        <box><size>0.3 0.3 0.29</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="plinth_6_visual">
                    <geometry>
                        <box><size>0.3 0.3 0.29</size></box>
                    </geometry>
                    <material>
                        <ambient>0.45 0.45 0.45 1.0</ambient>
                        <diffuse>0.60 0.60 0.60 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- 石墩7: x=12.8 (间距0.15m, 最后一阶紧贴楼梯), 高0.30m → 顶面 z=0.50 -->
            <link name="plinth_7">
                <pose>12.8 0 0.35 0 0 0</pose>
                <collision name="plinth_7_collision">
                    <geometry>
                        <box><size>0.3 0.3 0.30</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="plinth_7_visual">
                    <geometry>
                        <box><size>0.3 0.3 0.30</size></box>
                    </geometry>
                    <material>
                        <ambient>0.45 0.45 0.45 1.0</ambient>
                        <diffuse>0.60 0.60 0.60 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- ========================================================
               3. 破损的检修楼梯与平台 (13.0m - 15.9m)
                  3级台阶从泥泞区(z=0.2)升至平台(z=0.5)，每级高0.1m深0.3m
                  【关键破损】第2级台阶左半缺失 —— 盲走机器人左前足踩空
                  平台中央 0.5×0.5m 检修敞口 —— 盲走机器人直接坠落
               ======================================================== -->

            <!-- 台阶1（最下级）：x=13.0-13.3, z=0.2→0.3, 高0.1m, 完整 -->
            <link name="step_1">
                <pose>13.15 0 0.25 0 0 0</pose>
                <collision name="step_1_collision">
                    <geometry>
                        <box><size>0.3 2.0 0.1</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="step_1_visual">
                    <geometry>
                        <box><size>0.3 2.0 0.1</size></box>
                    </geometry>
                    <material>
                        <!-- 工业安全黄 -->
                        <ambient>0.5 0.4 0.0 1.0</ambient>
                        <diffuse>0.8 0.6 0.0 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!--
                台阶2（中间级）：x=13.3-13.6, z=0.2→0.4, 高0.2m
                【破损】仅保留右半部分 (y>0)，左半(y<0)缺失
            -->
            <!-- 台阶2-右半（完好部分）：x=13.3-13.6, y=0-1.0 -->
            <link name="step_2_right">
                <pose>13.45 0.5 0.30 0 0 0</pose>
                <collision name="step_2_right_collision">
                    <geometry>
                        <box><size>0.3 1.0 0.2</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="step_2_right_visual">
                    <geometry>
                        <box><size>0.3 1.0 0.2</size></box>
                    </geometry>
                    <material>
                        <ambient>0.5 0.4 0.0 1.0</ambient>
                        <diffuse>0.8 0.6 0.0 1.0</diffuse>
                    </material>
                </visual>
            </link>
            <!--
                【台阶2左半缺失】x=13.3-13.6, y=-1.0~0
                此处无任何碰撞体，机器人左足将踩空坠落
            -->

            <!-- 台阶3（最上级）：x=13.6-13.9, z=0.2→0.5, 高0.3m, 完整 -->
            <link name="step_3">
                <pose>13.75 0 0.35 0 0 0</pose>
                <collision name="step_3_collision">
                    <geometry>
                        <box><size>0.3 2.0 0.3</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="step_3_visual">
                    <geometry>
                        <box><size>0.3 2.0 0.3</size></box>
                    </geometry>
                    <material>
                        <ambient>0.5 0.4 0.0 1.0</ambient>
                        <diffuse>0.8 0.6 0.0 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!--
                金属网格观测平台：x=13.9-15.9, 宽2.0m, 厚0.1m, 顶面 z=0.5
                【中央检修敞口】0.5m × 0.5m 方形洞口
                平台由4块 Box 拼成"回"字形框架，中央留空
            -->
            <!-- 平台前条：x=13.9-14.65, 全宽 -->
            <link name="platform_front">
                <pose>14.275 0 0.45 0 0 0</pose>
                <collision name="platform_front_collision">
                    <geometry>
                        <box><size>0.75 2.0 0.1</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="platform_front_visual">
                    <geometry>
                        <box><size>0.75 2.0 0.1</size></box>
                    </geometry>
                    <material>
                        <!-- 深色金属灰，模拟工业钢格栅 -->
                        <ambient>0.10 0.10 0.12 1.0</ambient>
                        <diffuse>0.20 0.20 0.24 1.0</diffuse>
                        <specular>0.3 0.3 0.3 1.0</specular>
                    </material>
                </visual>
            </link>

            <!-- 平台后条：x=15.15-15.9, 全宽 -->
            <link name="platform_back">
                <pose>15.525 0 0.45 0 0 0</pose>
                <collision name="platform_back_collision">
                    <geometry>
                        <box><size>0.75 2.0 0.1</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="platform_back_visual">
                    <geometry>
                        <box><size>0.75 2.0 0.1</size></box>
                    </geometry>
                    <material>
                        <ambient>0.10 0.10 0.12 1.0</ambient>
                        <diffuse>0.20 0.20 0.24 1.0</diffuse>
                        <specular>0.3 0.3 0.3 1.0</specular>
                    </material>
                </visual>
            </link>

            <!-- 平台左条：x=14.65-15.15, y=-1.0~-0.25 (洞口左侧) -->
            <link name="platform_left">
                <pose>14.9 -0.625 0.45 0 0 0</pose>
                <collision name="platform_left_collision">
                    <geometry>
                        <box><size>0.5 0.75 0.1</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="platform_left_visual">
                    <geometry>
                        <box><size>0.5 0.75 0.1</size></box>
                    </geometry>
                    <material>
                        <ambient>0.10 0.10 0.12 1.0</ambient>
                        <diffuse>0.20 0.20 0.24 1.0</diffuse>
                        <specular>0.3 0.3 0.3 1.0</specular>
                    </material>
                </visual>
            </link>

            <!-- 平台右条：x=14.65-15.15, y=0.25~1.0 (洞口右侧) -->
            <link name="platform_right">
                <pose>14.9 0.625 0.45 0 0 0</pose>
                <collision name="platform_right_collision">
                    <geometry>
                        <box><size>0.5 0.75 0.1</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="platform_right_visual">
                    <geometry>
                        <box><size>0.5 0.75 0.1</size></box>
                    </geometry>
                    <material>
                        <ambient>0.10 0.10 0.12 1.0</ambient>
                        <diffuse>0.20 0.20 0.24 1.0</diffuse>
                        <specular>0.3 0.3 0.3 1.0</specular>
                    </material>
                </visual>
            </link>
            <!--
                【中央检修敞口】x=14.65-15.15, y=-0.25-0.25
                0.5m × 0.5m 方形洞口，无碰撞体，机器人坠落至泥泞区(z=0.2)
            -->

            <!-- 平台护栏 - 左侧 -->
            <link name="guardrail_left_top">
                <pose>14.9 1.01 0.95 0 0 0</pose>
                <collision name="guardrail_left_top_collision">
                    <geometry>
                        <box><size>2.0 0.03 0.03</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="guardrail_left_top_visual">
                    <geometry>
                        <box><size>2.0 0.03 0.03</size></box>
                    </geometry>
                    <material>
                        <!-- 黄色安全护栏 -->
                        <ambient>0.6 0.5 0.0 1.0</ambient>
                        <diffuse>0.9 0.75 0.0 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- 平台护栏 - 右侧 -->
            <link name="guardrail_right_top">
                <pose>14.9 -1.01 0.95 0 0 0</pose>
                <collision name="guardrail_right_top_collision">
                    <geometry>
                        <box><size>2.0 0.03 0.03</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="guardrail_right_top_visual">
                    <geometry>
                        <box><size>2.0 0.03 0.03</size></box>
                    </geometry>
                    <material>
                        <ambient>0.6 0.5 0.0 1.0</ambient>
                        <diffuse>0.9 0.75 0.0 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- ========================================================
               4. 安全下行坡道 (15.9m - 18.9m)
                  从平台顶面(z=0.5)缓缓下降至地面(z=0)，长3m
                  Box 绕 Y 轴旋转实现斜坡
                  角度 = atan(0.5/3) ≈ 9.46° ≈ 0.165 rad
                  斜长 = sqrt(3² + 0.5²) ≈ 3.041m
               ======================================================== -->
            <link name="exit_ramp">
                <!--
                    x_center = (15.9 + 18.9) / 2 = 17.4
                    z_center = (0.5 + 0.0) / 2 = 0.25
                    pitch = -atan(0.5/3) = -0.165 rad (绕Y轴下倾)
                -->
                <pose>17.4 0 0.25 0 -0.165 0</pose>
                <collision name="exit_ramp_collision">
                    <geometry>
                        <box><size>3.041 2.0 0.1</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="exit_ramp_visual">
                    <geometry>
                        <box><size>3.041 2.0 0.1</size></box>
                    </geometry>
                    <material>
                        <!-- 防滑混凝土灰 -->
                        <ambient>0.35 0.35 0.35 1.0</ambient>
                        <diffuse>0.50 0.50 0.50 1.0</diffuse>
                    </material>
                </visual>
            </link>

            <!-- ========================================================
               5. 巡检目标柜 (x=17.5, y=1.6)
                  模拟变电站末端电气柜，作为巡检任务终点参考物
               ======================================================== -->
            <link name="inspection_cabinet">
                <pose>17.5 1.6 0.4 0 0 0</pose>
                <collision name="inspection_cabinet_collision">
                    <geometry>
                        <box><size>0.5 0.4 0.8</size></box>
                    </geometry>
                    <surface>
                        <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
                    </surface>
                </collision>
                <visual name="inspection_cabinet_visual">
                    <geometry>
                        <box><size>0.5 0.4 0.8</size></box>
                    </geometry>
                    <material>
                        <!-- 工业电气柜绿色 -->
                        <ambient>0.08 0.13 0.08 1.0</ambient>
                        <diffuse>0.18 0.30 0.18 1.0</diffuse>
                    </material>
                </visual>
            </link>

        </model>
    </world>
</sdf>
